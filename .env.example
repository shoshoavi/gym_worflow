# Copy to .env in repo root or backend/.env — used by FastAPI (pydantic-settings loads backend/.env if cwd is backend)

DATABASE_URL=postgresql://gym:gym@localhost:5432/gymbot
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
DEBUG=true

# Optional: HMAC or shared secret for CRM webhooks (implement verify in webhooks.py)
# CRM_WEBHOOK_SECRET=

# Twilio (optional — outbound still stub until wired)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# n8n outbound webhook — backend POSTs queued template jobs here for delivery.
# Leave unset in dev to keep jobs in `queued` state without dispatching.
# N8N_OUTBOUND_WEBHOOK_URL=https://whatsappchatbotai.app.n8n.cloud/webhook/template-job
